ftg_repo/

# Local-only suggestion files + one-off helpers (don't commit)
FINAL_REPORT_ADDITIONS.md
FINAL_REPORT_EDITS.md
FINAL_REPORT_EDITS.docx
_apply_docx_updates.py
_make_report_edits_docx.py
_apply_report_footnotes.py

# Word lock files (~$ prefix when a .docx is open)
~$*.docx
~$*.doc

# Top-level transient stdout logs from run_all_drifts.py post-steps
# (per-snapshot stdout logs INSIDE each snapshot folder are committed
# alongside the snapshot for traceability; these top-level ones are
# regenerated on every wrapper run and add no committable value)
example_outputs_TEMPORARY/compare_snapshots_stdout*.log
example_outputs_TEMPORARY/variable_cost_stdout.log
finalized_outputs/compare_snapshots_stdout*.log
finalized_outputs/run_all_drifts_stdout*.log
finalized_outputs/run_all_drifts_stderr*.log
finalized_outputs/variable_cost_stdout.log
finalized_outputs/regen_k_sweep_*_stdout.log
finalized_outputs/regen_k_sweep_*_stderr.log

# Transient LP solver bundle pickles dropped inside snapshot dirs
# when a parallel run is interrupted (cleaned up by complete runs)
finalized_outputs/**/_solver_bundle_*.pkl
